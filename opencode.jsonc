{
  "$schema": "https://opencode.ai/config.json",
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000,
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      "coverage/**",
      ".git/**",
      ".vite/**",
      "playwright-report/**",
      "public/assets/pixel-art/**",
    ],
  },
}
